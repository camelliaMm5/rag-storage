# Embedding 模型名称（HuggingFace sentence-transformers）
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ChromaDB 持久化路径
CHROMA_DB_PATH=./chroma_db

# ChromaDB collection 名称
COLLECTION_NAME=faq_knowledge

# 文本切片参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 文档目录（批量导入时扫描的路径）
DOCS_DIR=./docs

# HuggingFace 离线模式（避免超时重试）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# LLM API 配置
LLM_API_KEY=sk-5a8500151c1443809c7d786136efc9f4
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 会话数据库
CONVERSATION_DB_URL=sqlite:///./conversations.db
